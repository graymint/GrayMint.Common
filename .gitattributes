# Normalize line endings: text files are stored as LF in the repo; working-tree endings follow
# each platform (CRLF on Windows) unless overridden below.
* text=auto

# Shell scripts must stay LF even on Windows (a CRLF shebang breaks them on Linux).
*.sh text eol=lf

# Binary assets — never normalize.
*.png binary
*.ico binary
*.snk binary
